# SSI FastConnect API - Điền thông tin từ iboard.ssi.com.vn
SSI_CONSUMER_ID=your_consumer_id
SSI_CONSUMER_SECRET=your_consumer_secret
SSI_PRIVATE_KEY=your_private_key

# OpenAI API Key (nếu dùng GPT-4)
OPENAI_API_KEY=sk-your-openai-key

# Hoặc dùng Ollama local (miễn phí, chạy local)
# Cài Ollama: brew install ollama && ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Chọn LLM provider: "openai" hoặc "ollama"
LLM_PROVIDER=ollama

# SSI API URLs
SSI_DATA_API_URL=https://fc-data.ssi.com.vn
SSI_TRADE_API_URL=https://fc-tradeapi.ssi.com.vn
SSI_STREAM_URL=wss://fc-datahub.ssi.com.vn
